# ============================================================
# IT 资产生命周期管理系统 —— 环境变量模板（.env.example）
# 使用步骤：
#   1) 复制本文件为 .env：  cp .env.example .env
#   2) 将下面所有 replace-with-* 占位符替换为真实值
#   3) 切勿把真实 .env 提交进 Git（已在 .gitignore 排除）
#
# 注意：SPRING_PROFILES_ACTIVE=prod 已在 docker-compose.yml 内固定，
#       无需、也无需在此文件中设置。
# ============================================================

# PostgreSQL
POSTGRES_DB=itam
POSTGRES_USER=itam
POSTGRES_PASSWORD=replace-with-random-password

# JWT（生成强随机串：openssl rand -base64 48）
ITAM_JWT_SECRET=replace-with-random-secret-at-least-32-bytes

# 前端对外端口（仅绑定 127.0.0.1，默认 3000；即 http://127.0.0.1:3000）
ITAM_PUBLIC_PORT=3000

# Redis 密码（如不需要可留空）
ITAM_REDIS_PASSWORD=
